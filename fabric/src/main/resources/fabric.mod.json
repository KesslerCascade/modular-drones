{
  "schemaVersion": 1,
  "id": "drones",
  "version": "${version}",
  "name": "Modular Drones",
  "description": "Allows you to build modular drones.",
  "authors": [
    "rearth",
    "KesslerCascade"
  ],
  "contact": {
    "homepage": "https://github.com/KesslerCascade/ModularDronesContinued",
    "sources": "https://github.com/KesslerCascade/ModularDronesContinued"
  },
  "license": "CC-BY-4.0",
  "icon": "assets/drones/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "rearth.fabric.DronesModFabric"
    ],
    "client": [
      "rearth.fabric.client.DronesModFabricClient"
    ],
    "fabric-datagen": [
      "rearth.fabric.DronesDataGenerator"
    ]
  },
  "mixins": [
    "drones.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~1.21.10",
    "java": ">=21",
    "architectury": ">=18.0.8",
    "fabric-api": "*"
  },
  "suggests": {
    "oracle-index": "*"
  }
}
